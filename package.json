{
  "name": "your-shop-here",
  "version": "1.0.0",
  "description": "An experimental reference storefront",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SalesforceCommerceCloud/sfcc-hooks-collection.git"
  },
  "keywords": [
    "ocapi",
    "rest",
    "headless",
    "ecommerce"
  ],
  "author": "Holger Nestmann",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/SalesforceCommerceCloud/sfcc-hooks-collection/issues"
  },
  "homepage": "https://github.com/SalesforceCommerceCloud/sfcc-hooks-collection#readme",
  "dependencies": {
    "@builder.io/partytown": "^0.10.3",
    "@qwik.dev/partytown": "^0.11.0",
    "@salesforce/b2c-cli": "^1.4.0",
    "chai": "^4.2.0",
    "chai-subset": "^1.5.0",
    "mocha": "^10.2.0",
    "mocha-junit-reporter": "^2.0.0",
    "npm-run-all": "^4.1.5"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-plugin-import": "^2.29.1"
  },
  "scripts": {
    "auth": "b2c auth login",
    "auth:unattended": "b2c auth client",
    "data:main-import": "b2c job import commerce-cloud-data/your-shop-here-data --wait --poll-interval 15",
    "data:testdata-rebuilddata": "b2c job run AfterDeploy --wait --poll-interval 15",
    "code:deploy": "b2c code deploy commerce-cloud-code/",
    "code:reload": "b2c code activate version1 --reload",
    "code:watch": "b2c code watch commerce-cloud-code/",
    "develop:switchcode": "b2c code activate version2 && b2c code activate version1",
    "bootstrap": "bash scripts/bootstrap.sh",
    "lint:js": "eslint .",
    "import-data": "npm-run-all auth data:main-import data:testdata-rebuilddata",
    "all": "npm-run-all auth data:main-import data:testdata-rebuilddata code:deploy code:reload",
    "unattended": "npm-run-all auth:unattended data:main-import data:testdata-rebuilddata code:deploy code:reload"
  }
}
